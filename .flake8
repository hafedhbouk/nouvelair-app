# =============================================================================
# Configuration Flake8 - NouvelAir
# =============================================================================
# Règles de linting pour le projet NouvelAir.
# Documentation: https://flake8.pycqa.org/en/latest/
# =============================================================================

[flake8]
ignore = E203, E266, E501, W503, W504
max-line-length = 120
exclude =
    migrations,
    venv,
    __pycache__,
    .git,
    .github,
    htmlcov,
    *.egg-info,
    build,
    dist,
    node_modules
per-file-ignores =
    tests/*: S101, S106
    */tests/*: S101
    manage.py: S101
    scripts/*: S101
# Format de sortie
format = default
show-source = true
statistics = true
count = true
